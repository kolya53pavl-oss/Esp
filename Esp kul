local function CreateBoneLine(parent)
    local Line = Instance.new("LineHandleAdornment")
    Line.Length = 0
    Line.Thickness = 2
    Line.ZIndex = 10
    Line.AlwaysOnTop = true
    Line.Visible = false
    Line.Parent = parent
    return Line
end

local function CreateESP(player)
    if player == LocalPlayer then return end

    local Bones = {}
    local SkeletonFolder = Instance.new("Folder")
    SkeletonFolder.Name = player.Name .. "_Skeleton"
    SkeletonFolder.Parent = ScreenGui

    local BonePairs = {
        {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
        {"Head", "Torso"},
        {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"},
        {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"},
        {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"},
        {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"},
        {"Torso", "Left Arm"}, {"Torso", "Right Arm"},
        {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
    }

    for i = 1, #BonePairs do
        Bones[i] = {Pair = BonePairs[i], Visual = CreateBoneLine(SkeletonFolder)}
    end

    local BoxGui = Instance.new("BillboardGui")
    BoxGui.Size = UDim2.new(4.5, 0, 6, 0)
    BoxGui.AlwaysOnTop = true
    BoxGui.ResetOnSpawn = false
    BoxGui.Enabled = false
    BoxGui.Parent = ScreenGui

    local BoxFrame = Instance.new("Frame")
    BoxFrame.Size = UDim2.new(1, 0, 1, 0)
    BoxFrame.BackgroundTransparency = 1
    BoxFrame.Parent = BoxGui

    local Stroke = Instance.new("UIStroke")
    Stroke.Thickness = 2
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    Stroke.Parent = BoxFrame

    local InfoLabel = Instance.new("TextLabel")
    InfoLabel.Size = UDim2.new(1, 0, 0, 22)
    InfoLabel.Position = UDim2.new(0, 0, 1, 3)
    InfoLabel.BackgroundTransparency = 1
    InfoLabel.Font = Enum.Font.SourceSansBold
    InfoLabel.TextSize = 14
    InfoLabel.TextStrokeTransparency = 0
    InfoLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    InfoLabel.Parent = BoxGui

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not player.Parent then
            BoxGui:Destroy()
            SkeletonFolder:Destroy()
            Connection:Disconnect()
            return
        end

        local char = player.Character
        local localChar = LocalPlayer.Character

        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and localChar and localChar:FindFirstChild("HumanoidRootPart") then
            
            local isTeam = (player.Team == LocalPlayer.Team and player.Team ~= nil)
            
            if not Settings.MasterToggle or (Settings.TeamCheck and isTeam) then
                BoxGui.Enabled = false
                for _, bone in ipairs(Bones) do bone.Visual.Visible = false end
                return
            end

            local CurrentColor = isTeam and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(255, 0, 0)
            
            BoxGui.Adornee = char.HumanoidRootPart
            Stroke.Color = CurrentColor
            InfoLabel.TextColor3 = CurrentColor

            local infoText = player.Name
            
            if Settings.ShowHealth then
                local currentHealth = math.clamp(char.Humanoid.Health, 0, char.Humanoid.MaxHealth)
                infoText = infoText .. " [" .. math.floor(currentHealth) .. " HP]"
            end
            
            if Settings.ShowDistance then
                local distance = (localChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                infoText = infoText .. " (" .. math.floor(distance) .. "m)"
            end

            InfoLabel.Text = infoText
            BoxGui.Enabled = true

            if Settings.ShowSkeleton then
                for _, bone in ipairs(Bones) do
                    local part1 = char:FindFirstChild(bone.Pair[1])
                    local part2 = char:FindFirstChild(bone.Pair[2])

                    if part1 and part2 then
                        local pos1 = part1.Position
                        local pos2 = part2.Position
                        
                        bone.Visual.CFrame = CFrame.new(pos1, pos2)
                        bone.Visual.Length = (pos1 - pos2).Magnitude
                        bone.Visual.Color3 = CurrentColor
                        bone.Visual.Visible = true
                        bone.Visual.Adornee = part1
                    else
                        bone.Visual.Visible = false
                    end
                end
            else
                for _, bone in ipairs(Bones) do bone.Visual.Visible = false end
            end
        else
            BoxGui.Enabled = false
            for _, bone in ipairs(Bones) do bone.Visual.Visible = false end
        end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do CreateESP(p) end
